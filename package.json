    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsc-watch": "^7.2.0",
    "typedoc": "^0.28.17",
    "typescript-eslint": "^8.57.0",
